# Copy to .env and fill in. Never commit .env.

# Signs session cookies + TOTP provisioning. Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-hex-string

# HuggingFace token with pyannote model licenses accepted.
# Required for diarization. Get one at https://hf.co/settings/tokens
# and accept the gated model terms at:
#   https://hf.co/pyannote/speaker-diarization-3.1
#   https://hf.co/pyannote/segmentation-3.0
HF_TOKEN=hf_xxx

# Redis (used by the arq job queue). Default works with docker-compose.
REDIS_URL=redis://localhost:6379

# Where uploads, outputs and the sqlite db live.
DATA_DIR=./data

# --- Model / GPU settings (worker) ---
WHISPER_MODEL=large-v3
# float16 on the 5080; use int8_float16 to save VRAM, float32 for CPU.
WHISPER_COMPUTE_TYPE=float16
WHISPER_DEVICE=cuda
WHISPER_BATCH_SIZE=16
# Speaker identification: cosine similarity above which a diarized voice is
# auto-labeled with a known person. Tune per diarization model (0.4-0.6).
SPEAKER_MATCH_THRESHOLD=0.5

# Override the diarization model (defaults to pyannote/speaker-diarization-3.1).
# DIARIZATION_MODEL=pyannote/speaker-diarization-3.1

# Speaker-embedding model used for voice identification (ungated by default).
# EMBEDDING_MODEL=speechbrain/spkrec-ecapa-voxceleb

# --- Upload limits ---
MAX_UPLOAD_MB=2048

# Set to true only when serving over HTTPS (your nginx terminates TLS),
# so the session cookie gets the Secure flag.
COOKIE_SECURE=true
